# Pulse Agent Configuration
# Copy to .env and fill in your values

# --- Claude API (choose one) ---

# Option 1: Vertex AI (recommended for GCP)
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=us-east5

# Option 2: Direct Anthropic API
# ANTHROPIC_API_KEY=

# --- Agent Settings ---
PULSE_AGENT_MODEL=claude-opus-4-6
PULSE_AGENT_MAX_TOKENS=16000
PULSE_AGENT_HARNESS=1

# --- WebSocket API ---
PULSE_AGENT_WS_TOKEN=
PULSE_AGENT_HOST=0.0.0.0
PULSE_AGENT_PORT=8080

# --- Memory (self-improving agent) ---
# PULSE_AGENT_MEMORY=1
# PULSE_AGENT_MEMORY_PATH=~/.pulse_agent/memory.db

# --- Circuit Breaker ---
PULSE_AGENT_CB_THRESHOLD=3
PULSE_AGENT_CB_TIMEOUT=60
