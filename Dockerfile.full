# Fallback single-stage Dockerfile — works without pre-built deps image.
# Slower (~5min) but always works. Used by deploy.sh when deps image is missing.
FROM registry.access.redhat.com/ubi9/python-312:latest
WORKDIR /opt/app-root/src

COPY pyproject.toml .
COPY sre_agent/ sre_agent/
RUN pip install --no-cache-dir .

USER 1001
EXPOSE 8080
CMD ["pulse-agent-api"]
